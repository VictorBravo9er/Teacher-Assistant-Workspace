      target_content: "@import url(\'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;750&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-mono: \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace;\n  --font-display: \"Space Grotesk\", sans-serif;\n  --color-slate-850: rgb(22, 30, 49);\n  --color-slate-905: rgb(11, 15, 27);\n}\n\n@layer base {\n  body {\n    @apply bg-[#0b0f19] text-gray-200 antialiased font-sans transition-colors duration-200 overflow-hidden;\n    font-feature-settings: \"cv02\", \"cv03\", \"cv04\", \"cv11\";\n  }\n\n  /* Custom high-tech translucent glass scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    @apply bg-slate-800/80 rounded-full hover:bg-slate-700/80 active:bg-slate-600/80;\n  }\n}\n\n/* Animations & Glassmorphism effects */\n.glass-panel {\n  @apply bg-[#0f172a]/30 backdrop-blur-xl border border-slate-850/40;\n}\n\n.glass-panel-heavy {\n  @apply bg-[#0f172a]/80 backdrop-blur-2xl border border-slate-800/60;\n}\n\n.glow-indigo {\n  box-shadow: 0 0 20px -5px rgba(99, 102, 241, 0.15);\n}\n\n.glow-emerald {\n  box-shadow: 0 0 20px -5px rgba(16, 185, 129, 0.15);\n}\n\n/* Custom pulsing live indicator */\n@keyframes pulse-ring {\n  0% { transform: scale(0.33); opacity: 1; }\n  80%, 100% { opacity: 0; }\n}\n.live-dot-ring {\n  animation: pulse-ring 1.25s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;\n}"
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;750&display=swap\');\n@import \"tailwindcss\";\n\n:root {\n  --background: #F8FAFC;\n  --surface: #FFFFFF;\n  --elevated: #F1F5F9;\n  --border-color: #CBD5E1;\n  --primary: #2563EB;\n  --secondary: #14B8A6;\n  --success: #22C55E;\n  --warning: #F59E0B;\n  --error: #EF4444;\n  --info: #38BDF8;\n  --primary-text: #0F172A;\n  --secondary-text: #334155;\n  --muted-text: #64748B;\n  --gold: #D4AF37;\n  \n  --chart-1: #2563EB;\n  --chart-2: #14B8A6;\n  --chart-3: #F59E0B;\n  --chart-4: #8B5CF6;\n  --chart-5: #22C55E;\n  --chart-6: #EC4899;\n}\n\n.dark {\n  --background: #0F172A;\n  --surface: #172033;\n  --elevated: #1E293B;\n  --border-color: #334155;\n  --primary: #60A5FA;\n  --secondary: #2DD4BF;\n  --success: #4ADE80;\n  --warning: #FBBF24;\n  --error: #F87171;\n  --info: #7DD3FC;\n  --primary-text: #F8FAFC;\n  --secondary-text: #CBD5E1;\n  --muted-text: #94A3B8;\n  --gold: #E6C75A;\n  \n  --chart-1: #60A5FA;\n  --chart-2: #2DD4BF;\n  --chart-3: #FBBF24;\n  --chart-4: #A78BFA;\n  --chart-5: #4ADE80;\n  --chart-6: #F472B6;\n}\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-mono: \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace;\n  --font-display: \"Space Grotesk\", sans-serif;\n  \n  --color-background: var(--background);\n  --color-surface: var(--surface);\n  --color-elevated: var(--elevated);\n  --color-border-color: var(--border-color);\n  --color-primary: var(--primary);\n  --color-secondary: var(--secondary);\n  --color-success: var(--success);\n  --color-warning: var(--warning);\n  --color-error: var(--error);\n  --color-info: var(--info);\n  --color-primary-text: var(--primary-text);\n  --color-secondary-text: var(--secondary-text);\n  --color-muted-text: var(--muted-text);\n  --color-gold: var(--gold);\n\n  --color-chart-1: var(--chart-1);\n  --color-chart-2: var(--chart-2);\n  --color-chart-3: var(--chart-3);\n  --color-chart-4: var(--chart-4);\n  --color-chart-5: var(--chart-5);\n  --color-chart-6: var(--chart-6);\n}\n\n@layer base {\n  body {\n    @apply bg-background text-primary-text antialiased font-sans transition-colors duration-200 overflow-hidden;\n    font-feature-settings: \"cv02\", \"cv03\", \"cv04\", \"cv11\";\n  }\n\n  /* Custom high-tech translucent glass scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    @apply bg-border-color/60 rounded-full hover:bg-border-color/80 active:bg-border-color;\n  }\n}\n\n/* Animations & Glassmorphism effects */\n.glass-panel {\n  @apply bg-surface/50 backdrop-blur-xl border border-border-color/50;\n}\n\n.glass-panel-heavy {\n  @apply bg-surface/90 backdrop-blur-2xl border border-border-color/80;\n}\n\n.glow-indigo {\n  box-shadow: 0 0 20px -5px rgba(37, 99, 235, 0.15);\n}\n\n.glow-emerald {\n  box-shadow: 0 0 20px -5px rgba(20, 184, 166, 0.15);\n}\n\n/* Custom pulsing live indicator */\n@keyframes pulse-ring {\n  0% { transform: scale(0.33); opacity: 1; }\n  80%, 100% { opacity: 0; }\n}\n.live-dot-ring {\n  animation: pulse-ring 1.25s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;\n}\n"
    }
