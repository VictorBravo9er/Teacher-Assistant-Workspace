    replacement_chunks {
      target_content: "// Interactive Pure SVG visualizer compiler\nfunction renderSvgVisualizer(visualization: any) {\n  const { type, data } = visualization;\n  if (!Array.isArray(data) || data.length === 0) return null;\n\n  switch (type) {\n    case \'ranking\':\n      return (\n        <div className=\"space-y-3 font-mono text-[11px]\">\n          {data.map((item: any, idx: number) => {\n            const pct = (item.score / 100) * 100;\n            return (\n              <div key={idx} className=\"space-y-1\">\n                <div className=\"flex justify-between text-slate-300\">\n                  <span className=\"font-semibold text-slate-200\">{item.name}</span>\n                  <span className=\"text-indigo-400 font-bold\">{item.score}%</span>\n                </div>\n                <div className=\"w-full h-2.5 bg-slate-900/80 border border-slate-850 rounded-full overflow-hidden flex relative\">\n                  <div \n                    className=\"h-full bg-gradient-to-r from-indigo-500 to-indigo-400 rounded-full transition-all duration-1000\"\n                    style={{ width: `${pct}%` }}\n                  ></div>\n                  {/* Class average guide overlay */}\n                  <div \n                    className=\"absolute h-full w-[2px] bg-emerald-400 top-0\"\n                    style={{ left: `${item.classAvg || 80}%` }}\n                    title=\"Class Average Line\"\n                  ></div>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      );\n\n    case \'timeline\':\n      // Renders score trajectory pathways simply using raw clean SVGs polylines\n      const points = data.map((item: any, idx: number) => {\n        const x = 50 + idx * 140;\n        const y = 140 - (item.SofiaScore || item.score || 50) * 1.1; // scale y\n        return { x, y, label: item.period || item.date };\n      });\n      const polylinePoints = points.map((p: any) => `${p.x},${p.y}`).join(\' \');\n\n      return (\n        <div className=\"flex flex-col gap-2\">\n          <svg className=\"w-full h-36 bg-slate-950/40 rounded-xl border border-slate-850 p-2\" viewBox=\"0 0 400 150\">\n            {/* Grid references lines */}\n            <line x1=\"40\" y1=\"30\" x2=\"380\" y2=\"30\" stroke=\"#1e293b\" strokeDasharray=\"3\" />\n            <line x1=\"40\" y1=\"85\" x2=\"380\" y2=\"85\" stroke=\"#1e293b\" strokeDasharray=\"3\" />\n            <line x1=\"40\" y1=\"130\" x2=\"380\" y2=\"130\" stroke=\"#1e293b\" strokeDasharray=\"3\" />\n\n            {/* Connecting Pathway vector line */}\n            <polyline \n              fill=\"none\" \n              stroke=\"#6366f1\" \n              strokeWidth=\"2.5\" \n              points={polylinePoints} \n              className=\"transition-all\"\n            />\n\n            {/* Marker Nodes */}\n            {points.map((p: any, idx: number) => (\n              <g key={idx}>\n                <circle \n                  cx={p.x} \n                  cy={p.y} \n                  r=\"5\" \n                  className=\"fill-[#0b0f19] stroke-indigo-400 stroke-2\" \n                />\n                <text \n                  x={p.x} \n                  y={p.y - 12} \n                  textAnchor=\"middle\" \n                  fill=\"#818cf8\" \n                  fontSize=\"10\" \n                  fontFamily=\"monospace\"\n                >\n                  {Math.round(140 - p.y) / 1.1}%\n                </text>\n                <text \n                  x={p.x} \n                  y=\"145\" \n                  textAnchor=\"middle\" \n                  fill=\"#475569\" \n                  fontSize=\"8\" \n                  fontFamily=\"monospace\"\n                >\n                  {p.label}\n                </text>\n              </g>\n            ))}\n          </svg>\n        </div>\n      );\n\n    case \'heatmap\':\n      // Renders colored bento boxes corresponding to individual topic scores\n      return (\n        <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3\">\n          {data.map((item: any, idx: number) => {\n            const mastery = item.mastery || 60;\n            let theme = \'border-rose-500/20 bg-rose-500/5 text-rose-400\';\n            let label = \'Urgent Remedial\';\n            if (mastery >= 85) {\n              theme = \'border-emerald-500/20 bg-emerald-500/5 text-emerald-400\';\n              label = \'Secure Mastery\';\n            } else if (mastery >= 70) {\n              theme = \'border-indigo-500/20 bg-indigo-500/5 text-indigo-400\';\n              label = \'Developing\';\n            }\n\n            return (\n              <div key={idx} className={`border rounded-xl p-3 flex flex-col gap-1 transition-colors ${theme}`}>\n                <span className=\"text-[9px] font-mono font-bold tracking-wider block uppercase\">{label}</span>\n                <span className=\"text-xs font-bold font-display truncate block mt-1\">{item.topic || item.subject}</span>\n                <h5 className=\"text-md font-extrabold font-mono mt-1\">{mastery}%</h5>\n              </div>\n            );\n          })}\n        </div>\n      );\n\n    case \'stats\':\n    default:\n      return (\n        <div className=\"grid grid-cols-2 gap-3.5\">\n          {data.map((item: any, idx: number) => (\n            <div key={idx} className=\"bg-slate-900/60 border border-slate-850/60 rounded-xl p-3 flex flex-col justify-between\">\n              <span className=\"text-[10px] font-mono text-slate-500 block uppercase leading-tight\">{item.label}</span>\n              <span className=\"text-xs font-bold text-slate-200 mt-2 block break-words\">{item.value}</span>\n            </div>\n          ))}\n        </div>\n      );\n  }\n}"
      replacement_content: "// Interactive Pure SVG visualizer compiler\nfunction renderSvgVisualizer(visualization: any) {\n  const { type, data } = visualization;\n  if (!Array.isArray(data) || data.length === 0) return null;\n\n  switch (type) {\n    case \'ranking\':\n      return (\n        <div className=\"space-y-3 font-mono text-[11px]\">\n          {data.map((item: any, idx: number) => {\n            const pct = (item.score / 100) * 100;\n            return (\n              <div key={idx} className=\"space-y-1\">\n                <div className=\"flex justify-between text-secondary-text\">\n                  <span className=\"font-semibold text-primary-text\">{item.name}</span>\n                  <span className=\"text-primary font-bold\">{item.score}%</span>\n                </div>\n                <div className=\"w-full h-2.5 bg-elevated border border-border-color rounded-full overflow-hidden flex relative\">\n                  <div \n                    className=\"h-full bg-gradient-to-r from-primary to-primary/80 rounded-full transition-all duration-1000\"\n                    style={{ width: `${pct}%` }}\n                  ></div>\n                  {/* Class average guide overlay */}\n                  <div \n                    className=\"absolute h-full w-[2px] bg-success top-0\"\n                    style={{ left: `${item.classAvg || 80}%` }}\n                    title=\"Class Average Line\"\n                  ></div>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      );\n\n    case \'timeline\':\n      // Renders score trajectory pathways simply using raw clean SVGs polylines\n      const points = data.map((item: any, idx: number) => {\n        const x = 50 + idx * 140;\n        const y = 140 - (item.SofiaScore || item.score || 50) * 1.1; // scale y\n        return { x, y, label: item.period || item.date };\n      });\n      const polylinePoints = points.map((p: any) => `${p.x},${p.y}`).join(\' \');\n\n      return (\n        <div className=\"flex flex-col gap-2\">\n          <svg className=\"w-full h-36 bg-elevated/40 rounded-xl border border-border-color p-2\" viewBox=\"0 0 400 150\">\n            {/* Grid references lines */}\n            <line x1=\"40\" y1=\"30\" x2=\"380\" y2=\"30\" stroke=\"var(--border-color)\" strokeDasharray=\"3\" opacity=\"0.4\" />\n            <line x1=\"40\" y1=\"85\" x2=\"380\" y2=\"85\" stroke=\"var(--border-color)\" strokeDasharray=\"3\" opacity=\"0.4\" />\n            <line x1=\"40\" y1=\"130\" x2=\"380\" y2=\"130\" stroke=\"var(--border-color)\" strokeDasharray=\"3\" opacity=\"0.4\" />\n\n            {/* Connecting Pathway vector line */}\n            <polyline \n              fill=\"none\" \n              stroke=\"var(--primary)\" \n              strokeWidth=\"2.5\" \n              points={polylinePoints} \n              className=\"transition-all\"\n            />\n\n            {/* Marker Nodes */}\n            {points.map((p: any, idx: number) => (\n              <g key={idx}>\n                <circle \n                  cx={p.x} \n                  cy={p.y} \n                  r=\"5\" \n                  className=\"fill-surface stroke-primary stroke-2\" \n                />\n                <text \n                  x={p.x} \n                  y={p.y - 12} \n                  textAnchor=\"middle\" \n                  fill=\"var(--primary)\" \n                  fontSize=\"10\" \n                  fontFamily=\"monospace\"\n                  fontWeight=\"bold\"\n                >\n                  {Math.round(140 - p.y) / 1.1}%\n                </text>\n                <text \n                  x={p.x} \n                  y=\"145\" \n                  textAnchor=\"middle\" \n                  fill=\"var(--muted-text)\" \n                  fontSize=\"8\" \n                  fontFamily=\"monospace\"\n                >\n                  {p.label}\n                </text>\n              </g>\n            ))}\n          </svg>\n        </div>\n      );\n\n    case \'heatmap\':\n      return (\n        <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3\">\n          {data.map((item: any, idx: number) => {\n            const mastery = item.mastery || 60;\n            let theme = \'border-error/30 bg-error/10 text-error\';\n            let label = \'Urgent Remedial\';\n            if (mastery >= 85) {\n              theme = \'border-success/30 bg-success/10 text-success\';\n              label = \'Secure Mastery\';\n            } else if (mastery >= 70) {\n              theme = \'border-secondary/30 bg-secondary/10 text-secondary\';\n              label = \'Developing\';\n            }\n\n            return (\n              <div key={idx} className={`border rounded-xl p-3 flex flex-col gap-1 transition-colors ${theme}`}>\n                <span className=\"text-[9px] font-mono font-bold tracking-wider block uppercase\">{label}</span>\n                <span className=\"text-xs font-bold font-display truncate block mt-1\">{item.topic || item.subject}</span>\n                <h5 className=\"text-md font-extrabold font-mono mt-1\">{mastery}%</h5>\n              </div>\n            );\n          })}\n        </div>\n      );\n\n    case \'stats\':\n    default:\n      return (\n        <div className=\"grid grid-cols-2 gap-3.5\">\n          {data.map((item: any, idx: number) => (\n            <div key={idx} className=\"bg-surface border border-border-color rounded-xl p-3 flex flex-col justify-between\">\n              <span className=\"text-[10px] font-mono text-muted-text block uppercase leading-tight\">{item.label}</span>\n              <span className=\"text-xs font-bold text-primary-text mt-2 block break-words\">{item.value}</span>\n            </div>\n          ))}\n        </div>\n      );\n  }\n}"
    }
