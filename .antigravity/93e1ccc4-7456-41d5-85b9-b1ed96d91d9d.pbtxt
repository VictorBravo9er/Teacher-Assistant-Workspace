border-indigo-500/80 bg-indigo-500/5 text-indigo-300 shadow-md\' \n                          : \'border-slate-850/50 hover:bg-slate-900/30 text-slate-400\'\n                      }`}\n                    >\n                      {type}\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n              {/* Scope selectors */}\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 uppercase block mb-1.5\">Focus Scope Bounds</label>\n                  <select \n                    value={analysisScope}\n                    onChange={(e) => setAnalysisScope(e.target.value as any)}\n                    className=\"w-full bg-slate-900 border border-slate-800 rounded-lg p-2 text-xs text-gray-350 cursor-pointer outline-none\"\n                  >\n                    <option value=\"class\">Entire Class Cohort</option>\n                    <option value=\"students\">Selected Students only</option>\n                    <option value=\"materials\">Uploaded Materials Repository</option>\n                    <option value=\"assessments\">Scored Grades Database</option>\n                  </select>\n                </div>\n\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 uppercase block mb-1.5\">Select specific bounds</label>\n                  {analysisScope === \'class\' ? (\n                    <div className=\"text-[11px] font-mono py-2 text-indigo-400 leading-normal\">\n                      Full class of {workspace.students.length} students indexed.\n                    </div>\n                  ) : (\n                    <div className=\"max-h-20 overflow-y-auto border border-slate-850 rounded-lg p-1.5 bg-slate-900 space-y-1\">\n                      {analysisScope === \'students\' && workspace.students.map(s => (\n                        <label key={s.id} className=\"flex items-center gap-1.5 text-xs text-slate-300\">\n                          <input \n                            type=\"checkbox\" \n                            checked={selectedScopeIds.includes(s.id)}\n                            onChange={(e) => {\n                              if (e.target.checked) setSelectedScopeIds([...selectedScopeIds, s.id]);\n                              else setSelectedScopeIds(selectedScopeIds.filter(id => id !== s.id));\n                            }}\n                          />\n                          {s.name}\n                        </label>\n                      ))}\n                      {analysisScope === \'materials\' && workspace.materials.map(m => (\n                        <label key={m.id} className=\"flex items-center gap-1.5 text-xs text-slate-350\">\n                          <input \n                            type=\"checkbox\" \n                            checked={selectedScopeIds.includes(m.id)}\n                            onChange={(e) => {\n                              if (e.target.checked) setSelectedScopeIds([...selectedScopeIds, m.id]);\n                              else setSelectedScopeIds(selectedScopeIds.filter(id => id !== m.id));\n                            }}\n                          />\n                          {m.name}\n                        </label>\n                      ))}\n                      {analysisScope === \'assessments\' && (\n                        <div className=\"text-[11px] font-mono text-indigo-400\">All quiz scoring records synced.</div>\n                      )}\n                    </div>\n                  )}\n                </div>\n              </div>\n\n              {/* Custom micro guidelines */}\n              <div>\n                <label className=\"text-[10px] font-mono text-slate-500 block mb-1\">OPTIONAL BRIEFING INSTRUCTIONS</label>\n                <textarea \n                  placeholder=\"Provide precise analysis directions, e.g. Cross-compare Aarav and Sofia\'s polynomials homework sheets specifically and look for IEP accommodations requirements...\"\n                  value={customBriefInstructions}\n                  onChange={(e) => setCustomBriefInstructions(e.target.value)}\n                  className=\"w-full bg-slate-900 border border-slate-800 rounded-lg p-2.5 text-xs text-slate-300 h-20 resize-none outline-none focus:border-indigo-500\"\n                />\n              </div>\n\n              <button \n                type=\"submit\"\n                className=\"w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-2 rounded-xl text-xs transition-colors shadow-lg cursor-pointer\"\n              >\n                Establish Chat Analysis Context\n              </button>\n\n            </form>\n          </div>"
