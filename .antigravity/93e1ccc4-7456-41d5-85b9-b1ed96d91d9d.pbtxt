        }
        lines {
          text: "                        const gradePercent = (grade.score / grade.maxScore) * 100;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        let gradeColor = \'text-green-400 bg-green-500/10 border-green-500/20\';"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                        if (gradePercent < 60) gradeColor = \'text-rose-400 bg-rose-500/10 border-rose-500/20\';"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                        else if (gradePercent < 75) gradeColor = \'text-amber-400 bg-amber-500/10 border-amber-500/20\';"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                        let gradeColor = \'text-success bg-success/10 border-success/20\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        if (gradePercent < 60) gradeColor = \'text-error bg-error/10 border-error/20\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        else if (gradePercent < 75) gradeColor = \'text-warning bg-warning/10 border-warning/20\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
