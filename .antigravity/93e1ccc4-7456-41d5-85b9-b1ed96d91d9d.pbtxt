steps {
  type: CORTEX_STEP_TYPE_USER_INPUT
  status: CORTEX_STEP_STATUS_DONE
  metadata {
    created_at {
      seconds: 1782019881
      nanos: 319966067
    }
    source: CORTEX_STEP_SOURCE_USER_EXPLICIT
    source_trajectory_step_info {
      trajectory_id: "93e1ccc4-7456-41d5-85b9-b1ed96d91d9d"
      step_index: 1
      cascade_id: "93e1ccc4-7456-41d5-85b9-b1ed96d91d9d"
    }
