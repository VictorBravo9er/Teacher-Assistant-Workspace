re(parseInt(e.target.value) || 0)}\n                              className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-1.8 text-xs text-gray-200 text-center\"\n                              min=\"0\"\n                              required\n                            />\n                            <span className=\"text-slate-600\">/</span>\n                            <input \n                              type=\"number\" \n                              value={newGradeMax}\n                              onChange={(e) => setNewGradeMax(parseInt(e.target.value) || 100)}\n                              className=\"w-14 bg-slate-950 border border-slate-800 rounded-lg p-1.8 text-xs text-gray-200 text-center\"\n                              min=\"1\"\n                              required\n                            />\n                          </div>\n                        </div>\n                      </div>\n\n                      <div>\n                        <label className=\"text-[10px] text-slate-500 font-mono block\">PORTFOLIO COMMENT FEEDBACK ENRICHMENT</label>\n                        <textarea \n                          placeholder=\"Provide encouraging assessment on concept development, e.g. Demonstrated solid operational mechanics...\"\n                          value={newGradeFeedback}\n                          onChange={(e) => setNewGradeFeedback(e.target.value)}\n                          className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-slate-300 h-16 resize-none outline-none\"\n                        />\n                      </div>\n\n                      <button \n                        type=\"submit\"\n                        className=\"bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold py-2 px-4 rounded-lg cursor-pointer\"\n                      >\n                        Commit Score Record\n                      </button>\n                    </form>\n                  )}\n\n                  {/* Scores tabular database */}\n                  <div className=\"space-y-3\">\n                    {selectedStudent.grades.length === 0 ? (\n                      <div className=\"text-center py-6 text-slate-500 text-xs font-mono border border-dashed border-slate-800/40 rounded-xl\">\n                        No evaluations logged. Record a score to establish performance trends.\n                      </div>\n                    ) : (\n                      selectedStudent.grades.map(grade => {\n                        const gradePercent = (grade.score / grade.maxScore) * 100;\n                        let gradeColor = \'text-green-400 bg-green-500/10 border-green-500/20\';\n                        if (gradePercent < 60) gradeColor = \'text-rose-400 bg-rose-500/10 border-rose-500/20\';\n                        else if (gradePercent < 75) gradeColor = \'text-amber-400 bg-amber-500/10 border-amber-500/20\';\n\n                        return (\n                          <div key={grade.id} className=\"bg-slate-900/40 border border-slate-850/60 hover:bg-slate-900/80 rounded-xl p-4 space-y-2 relative group transition-colors\">\n                            <div className=\"flex items-center justify-between\">\n                              <span className=\"text-xs font-medium text-slate-200\">{grade.assessmentName}</span>\n                              <div className=\"flex items-center gap-3\">\n                                <span className={`text-[10px] font-mono font-bold px-2 py-0.5 rounded border ${gradeColor}`}>\n                                  {grade.score} / {grade.maxScore} ({gradePercent.toFixed(0)}%)\n                                </span>\n                                <button \n                                  onClick={() => handleDeleteGrade(grade.id)}\n                                  className=\"opacity-0 group-hover:opacity-100 p-1 hover:bg-red-500/10 text-slate-500 hover:text-red-400 rounded cursor-pointer\"\n        