0 cursor-pointer\"\n                    >\n                      <option value=\"pdf\">PDF Document</option>\n                      <option value=\"doc\">Word Doc</option>\n                      <option value=\"book\">Reference Book</option>\n                      <option value=\"syllabus\">Syllabus Standard</option>\n                      <option value=\"custom\">General Form</option>\n                    </select>\n                  </div>\n                  <div>\n                    <label className=\"text-[10px] font-mono text-slate-500 block\">COMMA TAGS</label>\n                    <input \n                      type=\"text\" \n                      placeholder=\"Geometry, Exam\"\n                      value={newFileTags}\n                      onChange={(e) => setNewFileTags(e.target.value)}\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-gray-200 focus:outline-none\"\n                    />\n                  </div>\n                </div>\n\n                <button \n                  type=\"submit\"\n                  className=\"w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-xs py-2 rounded-lg transition-colors cursor-pointer\"\n                >\n                  Confirm Upload Simulation\n                </button>\n              </form>\n            )}\n\n            {/* Files Grid list */}\n            <div className=\"space-y-2.5\">\n              {workspace.materials.length === 0 ? (\n                <div className=\"text-center py-6 text-slate-500 text-xs font-mono border border-dashed border-slate-800/40 rounded-xl\">\n                  No reference files. Let\'s upload a textbook.\n                </div>\n              ) : (\n                workspace.materials.map(mat => (\n                  <div \n                    key={mat.id}\n                    className=\"group bg-slate-900/40 border border-slate-850/50 hover:bg-slate-900/80 rounded-xl p-3 flex items-center justify-between transition-colors cursor-pointer\"\n                  >\n                    <div className=\"flex items-center gap-3 truncate\" onClick={() => setSelectedMaterialHistory(mat)}>\n                      <div className=\"p-2.5 bg-slate-800/60 rounded-lg text-slate-400 group-hover:text-indigo-400 group-hover:bg-indigo-950/15 transition-all\">\n                        <FileText className=\"w-4 h-4\" />\n                      </div>\n                      <div className=\"truncate flex flex-col\">\n                        <span className=\"text-xs font-medium text-slate-200 truncate group-hover:text-gray-100\">{mat.name}</span>\n                        <div className=\"flex items-center gap-2 mt-1\">\n                          <span className=\"text-[9px] font-mono text-slate-500 uppercase\">{mat.type}</span>\n                          <span className=\"w-1 h-1 bg-slate-700 rounded-full\"></span>\n                          <span className=\"text-[9px] font-mono text-indigo-400/80\">{mat.size}</span>\n                        </div>\n                      </div>\n                    </div>\n\n                    <div className=\"flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity\">\n                      <button \n                        onClick={() => setSelectedMaterialHistory(mat)}\n                        title=\"View File Version History\"\n                        className=\"p-1 hover:bg-slate-850 text-slate-400 hover:text-indigo-400 rounded cursor-pointer\"\n                      >\n                        <History className=\"w-3.5 h-3.5\" />\n                      </button>\n                      <button \n                        onClick={() => onDeleteMaterial(workspace.id, mat.id)}\n                        title=\"Delete Document\"\n                        className=\"p-1 hover:bg-red-500/10 text-slate-500 hover:text-red-400 rounded cursor-pointer\"\n                      >\n                        <Trash2 className=\"w-3.5 h-3.5\" />\n                      </button>\n                    </div>\n                  </div>"
