      target_content: "    <div className=\"fixed inset-0 bg-slate-950/80 backdrop-blur-md flex items-start justify-center pt-[15vh] px-4 z-50 animate-fade-in\" onClick={() => setIsOpen(false)}>\n      <div \n        ref={commandPaletteRef}\n        onClick={(e) => e.stopPropagation()}\n        className=\"bg-[#0b0f19] border border-slate-800 rounded-2xl max-w-lg w-full overflow-hidden shadow-2xl glow-indigo\"\n      >\n        \n        {/* Input Bar */}\n        <div className=\"p-4 border-b border-slate-850 flex items-center gap-3\">\n          <Search className=\"w-5 h-5 text-indigo-400 shrink-0\" />\n          <input \n            type=\"text\" \n            placeholder=\"Type a command or student name... (e.g. Sofia, Focus, Physics)\"\n            value={query}\n            onChange={(e) => setQuery(e.target.value)}\n            className=\"flex-1 bg-transparent text-sm text-gray-200 outline-none placeholder-slate-500\"\n            autoFocus\n          />\n          <span className=\"text-[10px] font-mono bg-slate-800 text-slate-400 px-2 py-0.5 border border-slate-700 rounded-md\">\n            ESC\n          </span>\n        </div>\n\n        {/* Command Body */}\n        <div className=\"max-h-72 overflow-y-auto p-2 space-y-3\">\n          \n          {/* Quick Actions */}\n          <div className=\"space-y-1\">\n            <span className=\"text-[9px] font-mono font-bold text-slate-500 uppercase px-2 py-1 block\">Quick System Controls</span>\n            \n            <div \n              onClick={handleToggleFocus}\n              className=\"flex items-center justify-between px-3 py-2 rounded-xl hover:bg-slate-900 text-xs text-slate-300 hover:text-gray-100 transition-all cursor-pointer\"\n            >\n              <div className=\"flex items-center gap-2.5\">\n                <Minimize className=\"w-4 h-4 text-emerald-400\" />\n                <span>Toggle Immersive Chat Focus Mode</span>\n              </div>\n              <span className=\"text-[10px] text-slate-500 font-mono\">[{isFocusMode ? \'ON\' : \'OFF\'}]</span>\n            </div>\n          </div>\n\n          {/* Classes Result */}\n          {filteredWorkspaces.length > 0 && (\n            <div className=\"space-y-1\">\n              <span className=\"text-[9px] font-mono font-bold text-slate-500 uppercase px-2 py-1 block\">Switch Class Workspace</span>\n              {filteredWorkspaces.map(ws => (\n                <div \n                  key={ws.id}\n                  onClick={() => handleSelectWorkspace(ws.id)}\n                  className=\"flex items-center gap-2.5 px-3 py-2 rounded-xl hover:bg-slate-900 text-xs text-slate-350 hover:text-gray-100 transition-all cursor-pointer\"\n                >\n                  <BookOpen className=\"w-4 h-4 text-indigo-400\" />\n                  <span>{ws.name} ({ws.subject || \'Syllabus\'})</span>\n                </div>\n              ))}\n            </div>\n          )}\n\n          {/* Active students result */}\n          {filteredStudents.length > 0 && (\n            <div className=\"space-y-1\">\n              <span className=\"text-[9px] font-mono font-bold text-slate-500 uppercase px-2 py-1 block\">Active Class Students Roster</span>\n              {filteredStudents.map(stud => (\n                <div \n                  key={stud.id}\n                  onClick={() => handleSelectStudent(stud.id)}\n                  className=\"flex items-center gap-2.5 px-3 py-2 rounded-xl hover:bg-slate-900 text-xs text-slate-350 hover:text-gray-100 transition-all cursor-pointer animate-fade-in\"\n                >\n                  <User className=\"w-4 h-4 text-indigo-400/80\" />\n                  <div className=\"flex-1 flex justify-between\">\n                    <span>{stud.name}</span>\n                    <span className=\"text-[10px] font-mono text-slate-500\">Roll: {stud.rollNumber}</span>\n                  </div>\n                </div>\n              ))}\n            </div>\n          )}\n\n          {/* No matches */}\n          {filteredStudents.length === 0 && filteredWorkspaces.length === 0 && (\n            <div className=\"text-center py-6 text-slate-600 font-mono text-xs\">\n              No match for \"{query}\"\n            </div>\n          )}\n\n        </div>\n\n        {/* Footer shortcuts metadata */}\n        <div className=\"p-2.5 bg-slate-900/60 border-t border-slate-850 text-center text-[10px] font-mono text-slate-500\">\n          Tip: Press <kbd className=\"bg-slate-850 px-1 py-0.2 rounded border border-slate-700 font-bold\">Cmd K</kbd> to launch palette anytime.\n        </div>"
