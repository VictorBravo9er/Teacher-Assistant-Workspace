ont-mono\">FILE ATTACHMENT NAME</label>\n                          <input \n                            type=\"text\" \n                            placeholder=\"Midterm_Page3_SofiaRevision.pdf\"\n                            value={newUploadName}\n                            onChange={(e) => setNewUploadName(e.target.value)}\n                            className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-1.8 text-xs text-gray-200 outline-none\"\n                            required\n                          />\n                        </div>\n\n                        <div>\n                          <label className=\"text-[10px] text-slate-500 font-mono\">ASSIGNMENT TYPE</label>\n                          <select \n                            value={newUploadType}\n                            onChange={(e) => setNewUploadType(e.target.value)}\n                            className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-1.8 text-xs text-gray-300 outline-none cursor-pointer\"\n                          >\n                            <option value=\"Homework Submission\">Homework Revision</option>\n                            <option value=\"Written Midterm Submission\">Written Exam Sheet</option>\n                            <option value=\"Practical Lab Notebook\">Lab notebook index</option>\n                            <option value=\"Evaluation Sheet feedback\">Remedial feedback draft</option>\n                          </select>\n                        </div>\n                      </div>\n\n                      <button \n                        type=\"submit\"\n                        className=\"bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold py-2 px-4 rounded-lg cursor-pointer\"\n                      >\n                        Acknowledge File Log\n                      </button>\n                    </form>\n                  )}\n\n                  <div className=\"space-y-2.5\">\n               