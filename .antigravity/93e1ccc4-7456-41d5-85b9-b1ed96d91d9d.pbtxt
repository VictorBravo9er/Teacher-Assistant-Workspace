    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Workspace, Material, Instruction } from \'../types\';\nimport { \n  Building2, \n  BookMarked, \n  History, \n  Trash2, \n  Plus, \n  Tag, \n  Paperclip, \n  ChevronRight, \n  Calendar, \n  Sparkles, \n  FileText, \n  Award,\n  Globe,\n  Settings,\n  X,\n  PlusCircle,\n  FileCheck2,\n  Info\n} from \'lucide-react\';\n\ninterface WorkspaceDetailsProps {\n  workspace: Workspace;\n  onUpdateWorkspace: (id: string, updatedFields: Partial<Workspace>) => void;\n  onAddMaterial: (workspaceId: string, material: Omit<Material, \'id\' | \'uploadDate\'>) => void;\n  onDeleteMaterial: (workspaceId: string, materialId: string) => void;\n  onAddInstruction: (workspaceId: string, instruction: Omit<Instruction, \'id\'>) => void;\n  onDeleteInstruction: (workspaceId: string, instructionId: string) => void;\n}\n\nexport default function WorkspaceDetails({\n  workspace,\n  onUpdateWorkspace,\n  onAddMaterial,\n  onDeleteMaterial,\n  onAddInstruction,\n  onDeleteInstruction\n}: WorkspaceDetailsProps) {\n  const [activeSubTab, setActiveSubTab] = useState<\'profile\' | \'materials\' | \'prompts\'>(\'profile\');\n  \n  // Local form states for files/materials\n  const [newFileName, setNewFileName] = useState(\'\');\n  const [newFileType, setNewFileType] = useState<Material[\'type\']>(\'pdf\');\n  const [newFileTags, setNewFileTags] = useState(\'\');\n  const [showFileForm, setShowFileForm] = useState(false);\n\n  // Local form states for reusable instructions\n  const [newPromptTitle, setNewPromptTitle] = useState(\'\');\n  const [newPromptType, setNewPromptType] = useState<Instruction[\'type\']>(\'criteria\');\n  const [newPromptContent, setNewPromptContent] = useState(\'\');\n  const [showPromptForm, setShowPromptForm] = useState(false);\n\n  // Selected material for Version Log Modal\n  const [selectedMaterialHistory, setSelectedMaterialHistory] = useState<Material | null>(null);\n\n  const handleCreateMaterial = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newFileName.trim()) return;\n    \n    const tagsArr = newFileTags\n      .split(\',\')\n      .map(t => t.trim())\n      .filter(t => t.length > 0);\n\n    onAddMaterial(workspace.id, {\n      name: newFileName.trim(),\n      type: newFileType,\n      size: `${(Math.random() * 4 + 0.5).toFixed(1)} MB`,\n      tags: tagsArr.length > 0 ? tagsArr : [\'General\'],\n      versionHistory: [\n        { version: \'v1.0\', date: new Date().toISOString().split(\'T\')[0], note: \'Uploaded initial document\' }\n      ]\n    });\n\n    setNewFileName(\'\');\n    setNewFileTags(\'\');\n    setShowFileForm(false);\n  };\n\n  const handleCreateInstruction = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newPromptTitle.trim() || !newPromptContent.trim()) return;\n\n    onAddInstruction(workspace.id, {\n      title: newPromptTitle.trim(),\n      type: newPromptType,\n      content: newPromptContent.trim()\n    });\n\n    setNewPromptTitle(\'\');\n    setNewPromptContent(\'\');\n    setShowPromptForm(false);\n  };\n\n  return (\n    <div className=\"glass-panel rounded-2xl border border-slate-800/60 flex flex-col h-full bg-[#0c1325]/45 hover:border-slate-800/80 transition-colors overflow-hidden\">\n      \n      {/* Mini Tabs Header */}\n      <div className=\"flex border-b border-slate-850/60 p-1 bg-slate-900/60 shrink-0\">\n        <button \n          onClick={() => setActiveSubTab(\'profile\')}\n          className={`flex-1 py-2 text-xs font-semibold rounded-lg transition-all flex items-center justify-center gap-1.5 cursor-pointer ${\n            activeSubTab === \'profile\' \n              ? \'bg-[#1e294b] text-indigo-300 shadow\' \n              : \'text-slate-400 hover:text-gray-200\'\n          }`}\n        >\n          <Building2 className=\"w-3.5 h-3.5\" />\n          Class Profile\n        </button>\n        <button \n          onClick={() => setActiveSubTab(\'materials\')}\n          className={`relative flex-1 py-12 px-2 text-xs font-semibold rounded-lg transition-all flex items-center justify-center gap-1.5 cursor-pointer ${\n            activeSubTab === \'materials\' \n              ? \'bg-[#1e294b] text-indigo-300 shadow\' \n              : \'text-slate-400 hover:text-gray-200\'\n          }`}\n          style={{ padding: \"0.5rem 0.25rem\" }}\n        >\n          <BookMarked className=\"w-3.5 h-3.5\" />\n          Materials\n          {workspace.materials.length > 0 && (\n            <span className=\"ml-1 px-1.5 py-0.2 bg-indigo-500/20 text-indigo-300 text-[10px] rounded-full font-mono border border-indigo-500/20\">\n              {workspace.materials.length}\n            </span>\n          )}\n        </button>\n        <button \n          onClick={() => setActiveSubTab(\'prompts\')}\n          className={`flex-1 py-2 text-xs font-semibold rounded-lg transition-all flex items-center justify-center gap-1.5 cursor-pointer ${\n            activeSubTab === \'prompts\' \n              ? \'bg-[#1e294b] text-indigo-300 shadow\' \n              : \'text-slate-400 hover:text-gray-200\'\n          }`}\n        >\n          <Award className=\"w-3.5 h-3.5\" />\n          AI Instructions\n          {workspace.instructions.length > 0 && (\n            <span className=\"ml-1 px-1.5 py-0.2 bg-emerald-500/20 text-emerald-300 text-[10px] rounded-full font-mono border border-emerald-500/20\">\n              {workspace.instructions.length}\n            </span>\n          )}\n        </button>\n      </div>\n\n      {/* Tab Contents Area */}\n      <div className=\"flex-1 overflow-y-auto p-4\">\n        \n        {/* Profile Tab */}\n        {activeSubTab === \'profile\' && (\n          <div className=\"space-y-4\">\n            \n            {/* Lead Class Metrics Cards */}\n            <div className=\"grid grid-cols-2 gap-3\">\n              <div className=\"bg-slate-900/60 border border-slate-800/40 rounded-xl p-3\">\n                <span className=\"text-[10px] font-mono text-slate-500 block uppercase\">Curriculum Course</span>\n                <span className=\"text-xs font-semibold text-gray-200 block mt-1 truncate\">{workspace.subject}</span>\n              </div>\n              <div className=\"bg-slate-900/60 border border-slate-800/40 rounded-xl p-3\">\n                <span className=\"text-[10px] font-mono text-slate-500 block uppercase\">Academic Period</span>\n                <span className=\"text-xs font-semibold text-gray-200 block mt-1 truncate\">{workspace.semester}, {workspace.academicYear}</span>\n              </div>\n            </div>\n\n            {/* Teaching style details */}\n            <div className=\"bg-slate-900/40 border border-slate-800/40 rounded-xl p-3.5 space-y-3.5\">\n              <div className=\"flex items-center gap-2 pb-2.5 border-b border-slate-800/50\">\n                <Globe className=\"w-4 h-4 text-indigo-400\" />\n                <h4 className=\"text-xs font-bold text-slate-300\">Teaching Methodology & Philosophy</h4>\n              </div>\n              \n              <div className=\"space-y-3\">\n                <div>\n                  <label className=\"text-[10px] uppercase font-mono text-slate-500\">Instructor style</label>\n                  <input \n                    type=\"text\"\n                    value={workspace.teachingStyle}\n                    onChange={(e) => onUpdateWorkspace(workspace.id, { teachingStyle: e.target.value })}\n                    className=\"w-full bg-transparent text-xs text-gray-200 font-semibold focus:outline-none focus:border-b focus:border-indigo-500/50 pt-0.5\"\n                  />\n                </div>\n                \n                <div>\n                  <label className=\"text-[10px] uppercase font-mono text-slate-500\">Experience scale</label>\n                  <p className=\"text-xs font-medium text-slate-300 pt-0.5\">{workspace.experienceLevel}</p>\n                </div>\n\n                <div>\n                  <label className=\"text-[10px] uppercase font-mono text-slate-500\">Assessment Preferences</label>\n                  <textarea \n                    value={workspace.assessmentPreferences || \'No specific preferences.\'}\n                    onChange={(e) => onUpdateWorkspace(workspace.id, { assessmentPreferences: e.target.value })}\n                    className=\"w-full bg-transparent text-xs text-slate-300 h-10 resize-none focus:outline-none focus:border-b focus:border-indigo-500/50 pt-0.5\"\n                  />\n                </div>\n\n                <div>\n                  <label className=\"text-[10px] uppercase font-mono text-slate-500\">Workspace Reminders / Notes</label>\n                  <textarea \n                    value={workspace.specialNotes || \'\'}\n                    onChange={(e) => onUpdateWorkspace(workspace.id, { specialNotes: e.target.value })}\n                    placeholder=\"E.g. Focus on bridging Algebra basics before Geometry exams...\"\n                    className=\"w-full bg-slate-900 border border-slate-800 rounded-lg p-2 text-xs text-slate-300 h-14 resize-none focus:outline-none focus:border-indigo-500/30\"\n                  />\n                </div>\n              </div>\n            </div>\n            \n            {/* Instructional helper warning */}\n            <div className=\"bg-indigo-950/20 border border-indigo-900/35 rounded-xl p-3 flex gap-2.5\">\n              <Info className=\"w-4 h-4 text-indigo-400 shrink-0 mt-0.5\" />\n              <p className=\"text-[11px] text-indigo-300 leading-normal\">\n                Changes in this dossier automatically sync into the RAG Assistant scope. Chat searches will retrieve this context automatically.\n              </p>\n            </div>\n\n          </div>\n        )}\n\n        {/* Materials Repository Tab */}\n        {activeSubTab === \'materials\' && (\n          <div className=\"space-y-4\">\n            \n            <div className=\"flex items-center justify-between\">\n              <h4 className=\"text-xs font-bold text-slate-300 font-display\">Classroom Document Repo</h4>\n              <button \n                onClick={() => setShowFileForm(!showFileForm)}\n                className=\"text-xs font-semibold text-indigo-400 hover:text-indigo-300 flex items-center gap-1 cursor-pointer\"\n              >\n                {showFileForm ? <X className=\"w-3.5 h-3.5\" /> : <Plus className=\"w-3.5 h-3.5\" />}\n                {showFileForm ? \'Cancel\' : \'Upload File\'}\n              </button>\n            </div>\n\n            {/* Simulated file upload form */}\n            {showFileForm && (\n              <form onSubmit={handleCreateMaterial} className=\"bg-slate-900/80 border border-slate-800 rounded-xl p-3.5 space-y-3\">\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 block\">FILE DISPLAY TITLE</label>\n                  <input \n                    type=\"text\" \n                    placeholder=\"Geometry_Formulas_Apx.pdf\"\n                    value={newFileName}\n                    onChange={(e) => setNewFileName(e.target.value)}\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-gray-200 focus:outline-none focus:border-indigo-500\"\n                    required\n                  />\n                </div>\n                \n                <div className=\"grid grid-cols-2 gap-3\">\n                  <div>\n                    <label className=\"text-[10px] font-mono text-slate-500 block\">DOCUMENT TYPE</label>\n                    <select \n                      value={newFileType} \n                      onChange={(e) => setNewFileType(e.target.value as Material[\'type\'])}\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-gray-300 focus:outline-none focus:border-indigo-500 cursor-pointer\"\n                    >\n                      <option value=\"pdf\">PDF Document</option>\n                      <option value=\"doc\">Word Doc</option>\n                      <option value=\"book\">Reference Book</option>\n                      <option value=\"syllabus\">Syllabus Standard</option>\n                      <option value=\"custom\">General Form</option>\n                    </select>\n                  </div>\n                  <div>\n                    <label className=\"text-[10px] font-mono text-slate-500 block\">COMMA TAGS</label>\n                    <input \n                      type=\"text\" \n                      placeholder=\"Geometry, Exam\"\n                      value={newFileTags}\n                      onChange={(e) => setNewFileTags(e.target.value)}\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-gray-200 focus:outline-none\"\n                    />\n                  </div>\n                </div>\n\n                <button \n                  type=\"submit\"\n                  className=\"w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-xs py-2 rounded-lg transition-colors cursor-pointer\"\n                >\n                  Confirm Upload Simulation\n                </button>\n              </form>\n            )}\n\n            {/* Files Grid list */}\n            <div className=\"space-y-2.5\">\n              {workspace.materials.length === 0 ? (\n                <div className=\"text-center py-6 text-slate-500 text-xs font-mono border border-dashed border-slate-800/40 rounded-xl\">\n                  No reference files. Let\'s upload a textbook.\n                </div>\n              ) : (\n                workspace.materials.map(mat => (\n                  <div \n                    key={mat.id}\n                    className=\"group bg-slate-900/40 border border-slate-850/50 hover:bg-slate-900/80 rounded-xl p-3 flex items-center justify-between transition-colors cursor-pointer\"\n                  >\n                    <div className=\"flex items-center gap-3 truncate\" onClick={() => setSelectedMaterialHistory(mat)}>\n                      <div className=\"p-2.5 bg-slate-800/60 rounded-lg text-slate-400 group-hover:text-indigo-400 group-hover:bg-indigo-950/15 transition-all\">\n                        <FileText className=\"w-4 h-4\" />\n                      </div>\n                      <div className=\"truncate flex flex-col\">\n                        <span className=\"text-xs font-medium text-slate-200 truncate group-hover:text-gray-100\">{mat.name}</span>\n                        <div className=\"flex items-center gap-2 mt-1\">\n                          <span className=\"text-[9px] font-mono text-slate-500 uppercase\">{mat.type}</span>\n                          <span className=\"w-1 h-1 bg-slate-700 rounded-full\"></span>\n                          <span className=\"text-[9px] font-mono text-indigo-400/80\">{mat.size}</span>\n                        </div>\n                      </div>\n                    </div>\n\n                    <div className=\"flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity\">\n                      <button \n                        onClick={() => setSelectedMaterialHistory(mat)}\n                        title=\"View File Version History\"\n                        className=\"p-1 hover:bg-slate-850 text-slate-400 hover:text-indigo-400 rounded cursor-pointer\"\n                      >\n                        <History className=\"w-3.5 h-3.5\" />\n                      </button>\n                      <button \n                        onClick={() => onDeleteMaterial(workspace.id, mat.id)}\n                        title=\"Delete Document\"\n                        className=\"p-1 hover:bg-red-500/10 text-slate-500 hover:text-red-400 rounded cursor-pointer\"\n                      >\n                        <Trash2 className=\"w-3.5 h-3.5\" />\n                      </button>\n                    </div>\n                  </div>\n                ))\n              )}\n            </div>\n\n          </div>\n        )}\n\n        {/* AI Custom Instructions Tab */}\n        {activeSubTab === \'prompts\' && (\n          <div className=\"space-y-4\">\n            \n            <div className=\"flex items-center justify-between\">\n              <h4 className=\"text-xs font-bold text-slate-300 font-display\">Rule Prompt Templates</h4>\n              <button \n                onClick={() => setShowPromptForm(!showPromptForm)}\n                className=\"text-xs font-semibold text-emerald-400 hover:text-emerald-300 flex items-center gap-1 cursor-pointer\"\n              >\n                {showPromptForm ? <X className=\"w-3.5 h-3.5\" /> : <Plus className=\"w-3.5 h-3.5\" />}\n                {showPromptForm ? \'Cancel\' : \'New Guideline\'}\n              </button>\n            </div>\n\n            {/* Prompt design form */}\n            {showPromptForm && (\n              <form onSubmit={handleCreateInstruction} className=\"bg-slate-900/80 border border-slate-800 rounded-xl p-3.5 space-y-3\">\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 block\">INSTRUCTION TITLE</label>\n                  <input \n                    type=\"text\" \n                    placeholder=\"Socratic Equation Prompts\"\n                    value={newPromptTitle}\n                    onChange={(e) => setNewPromptTitle(e.target.value)}\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-gray-200 focus:outline-none\"\n                    required\n                  />\n                </div>\n\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 block\">GUIDELINE TYPE</label>\n                  <select \n                    value={newPromptType}\n                    onChange={(e) => setNewPromptType(e.target.value as Instruction[\'type\'])}\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-gray-300 focus:outline-none cursor-pointer\"\n                  >\n                    <option value=\"criteria\">Evaluation Criteria</option>\n                    <option value=\"marking\">Marking Instructions</option>\n                    <option value=\"preference\">Classroom Preferences</option>\n                    <option value=\"global\">Global Assistant system prompt</option>\n                  </select>\n                </div>\n\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 block\">AI INSTRUCTIONS CONTENT</label>\n                  <textarea \n                    placeholder=\"Direct the AI assistant to search for structural gaps rather than mathematical arithmetic omissions...\"\n                    value={newPromptContent}\n                    onChange={(e) => setNewPromptContent(e.target.value)}\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-slate-200 h-20 resize-none focus:outline-none\"\n                    required\n                  />\n                </div>\n\n                <button \n                  type=\"submit\"\n                  className=\"w-full bg-emerald-600 hover:bg-emerald-500 text-white font-semibold text-xs py-2 rounded-lg transition-colors cursor-pointer\"\n                >\n                  Save Guideline Rule\n                </button>\n              </form>\n            )}\n\n            {/* Prompts list */}\n            <div className=\"space-y-3\">\n              {workspace.instructions.length === 0 ? (\n                <div className=\"text-center py-6 text-slate-500 text-xs font-mono border border-dashed border-slate-800/40 rounded-xl\">\n                  No criteria instructions flagged. Assistant is using default grading rules.\n                </div>\n              ) : (\n                workspace.instructions.map(inst => (\n                  <div \n                    key={inst.id}\n                    className=\"bg-slate-900/30 border border-slate-850/60 rounded-xl p-3.5 space-y-2 hover:border-slate-800/70 transition-colors\"\n                  >\n                    <div className=\"flex items-center justify-between\">\n                      <span className=\"text-[10px] uppercase font-mono px-2 py-0.5 bg-slate-800 text-indigo-300 border border-slate-700 rounded-full font-semibold\">\n                        {inst.type}\n                      </span>\n                      <button \n                        onClick={() => onDeleteInstruction(workspace.id, inst.id)}\n                        className=\"text-slate-500 hover:text-red-400 p-1 rounded hover:bg-slate-850 transition-colors cursor-pointer\"\n                        title=\"Delete Guideline\"\n                      >\n                        <Trash2 className=\"w-3.5 h-3.5\" />\n                      </button>\n                    </div>\n                    <h5 className=\"text-xs font-bold text-gray-200\">{inst.title}</h5>\n                    <p className=\"text-[11px] text-slate-300 leading-relaxed font-mono whitespace-pre-line bg-slate-950/40 rounded-lg p-2 border border-slate-900/70\">\n                      {inst.content}\n                    </p>\n                  </div>\n                ))\n              )}\n            </div>\n\n          </div>\n        )}\n\n      </div>\n\n      {/* Version History Modal Overlay (simulated overlay) */}\n      {selectedMaterialHistory && (\n        <div className=\"fixed inset-0 bg-slate-950/80 backdrop-blur-sm flex items-center justify-center p-4 z-50\">\n          <div className=\"bg-[#0b0f19] border border-slate-800 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-2xl relative\">\n            <button \n              onClick={() => setSelectedMaterialHistory(null)}\n              className=\"absolute right-4 top-4 hover:bg-slate-850 p-1.5 rounded-lg text-slate-500 hover:text-gray-200 transition-colors cursor-pointer\"\n            >\n              <X className=\"w-4 h-4\" />\n            </button>\n\n            <div className=\"flex items-center gap-2.5 pb-2 border-b border-slate-800\">\n              <History className=\"w-5 h-5 text-indigo-400\" />\n              <div>\n                <h3 className=\"text-sm font-semibold text-gray-100 truncate max-w-xs\">{selectedMaterialHistory.name}</h3>\n                <span className=\"text-[10px] font-mono text-slate-500\">Document Upload Lifecycle</span>\n              </div>\n            </div>\n\n            <div className=\"space-y-3\">\n              {selectedMaterialHistory.versionHistory?.length > 0 ? (\n                selectedMaterialHistory.versionHistory.map((ver, idx) => (\n                  <div key={idx} className=\"flex gap-3 text-xs bg-slate-900/40 rounded-xl p-3 border border-slate-850/60\">\n                    <span className=\"font-mono text-indigo-400 font-bold shrink-0\">{ver.version}</span>\n                    <div className=\"space-y-0.5\">\n                      <span className=\"text-[10px] text-slate-500 font-mono block\">{ver.date}</span>\n                      <p className=\"text-slate-300 font-medium\">{ver.note}</p>\n                    </div>\n                  </div>\n                ))\n              ) : (\n                <div className=\"flex gap-3 text-xs bg-slate-900/40 rounded-xl p-3 border border-slate-850/60\">\n                  <span className=\"font-mono text-indigo-400 font-bold shrink-0\">v1.0</span>\n                  <div className=\"space-y-0.5\">\n                    <span className=\"text-[10px] text-slate-500 font-mono block\">{workspace.academicYear} semester release</span>\n                    <p className=\"text-slate-350\">Initial repository indexing completed.</p>\n                  </div>\n                </div>\n              )}\n\n              <button \n                onClick={() => {\n                  const note = prompt(\"Enter version update note:\");\n                  if (note) {\n                    const updatedVer = [...(selectedMaterialHistory.versionHistory || []), {\n                      version: `v1.${(selectedMaterialHistory.versionHistory?.length || 1)}`,\n                      date: new Date().toISOString().split(\'T\')[0],\n                      note\n                    }];\n                    const updatedMats = workspace.materials.map(m => \n                      m.id === selectedMaterialHistory.id ? { ...m, versionHistory: updatedVer } : m\n                    );\n                    onUpdateWorkspace(workspace.id, { materials: updatedMats });\n                    setSelectedMaterialHistory({ ...selectedMaterialHistory, versionHistory: updatedVer });\n                  }\n                }}\n                className=\"w-full bg-slate-900 hover:bg-slate-850 text-slate-300 hover:text-gray-100 font-mono text-[11px] py-1.5 border border-slate-800/80 rounded-lg transition-colors flex items-center justify-center gap-1.5 cursor-pointer mt-2\"\n              >\n                <PlusCircle className=\"w-3.5 h-3.5\" />\n                Commit Version Update Log\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n    </div>\n  );\n}\n"
    }
