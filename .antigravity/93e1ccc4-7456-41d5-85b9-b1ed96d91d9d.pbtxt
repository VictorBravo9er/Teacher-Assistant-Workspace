        }
        lines {
          text: "    case \'timeline\':"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      // Renders score trajectory pathways simply using raw clean SVGs polylines"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
