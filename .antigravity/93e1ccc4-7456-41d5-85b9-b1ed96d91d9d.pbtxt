  file_change {
    absolute_path_uri: "file:///src/components/RAGWorkspace.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useRef, useEffect } from \'react\';\nimport { Workspace, RAGSession, Message, Student, Material } from \'../types\';\nimport { \n  Plus, \n  Trash2, \n  Copy, \n  Archive, \n  Send, \n  Sparkles, \n  Bot, \n  User, \n  BarChart4, \n  Grid3X3, \n  TrendingUp, \n  FolderPlus, \n  Maximize2, \n  Minimize2, \n  ArrowLeft,\n  X,\n  FileSpreadsheet,\n  Check,\n  Flame,\n  Brain,\n  History,\n  Info\n} from \'lucide-react\';\n\ninterface RAGWorkspaceProps {\n  workspace: Workspace;\n  onUpdateWorkspace: (id: string, updatedFields: Partial<Workspace>) => void;\n  isFocusMode: boolean;\n  onToggleFocusMode: (focus: boolean) => void;\n  onSendChatMessage: (sessionId: string, text: string) => Promise<void>;\n  isGeneratingAI: boolean;\n}\n\nexport default function RAGWorkspace({\n  workspace,\n  onUpdateWorkspace,\n  isFocusMode,\n  onToggleFocusMode,\n  onSendChatMessage,\n  isGeneratingAI\n}: RAGWorkspaceProps) {\n  const [activeSessionId, setActiveSessionId] = useState<string | null>(null);\n  const [sessionSearch, setSessionSearch] = useState(\'\');\n  \n  // New session modal states\n  const [showNewSessionModal, setShowNewSessionModal] = useState(false);\n  const [analysisType, setAnalysisType] = useState(\'Student Performance Analysis\');\n  const [analysisScope, setAnalysisScope] = useState<\'class\' | \'students\' | \'materials\' | \'assessments\'>(\'class\');\n  const [selectedScopeIds, setSelectedScopeIds] = useState<string[]>([]);\n  const [customBriefInstructions, setCustomBriefInstructions] = useState(\'\');\n\n  // Chat bar input state\n  const [chatInput, setChatInput] = useState(\'\');\n  const chatBottomRef = useRef<HTMLDivElement | null>(null);\n\n  // Dynamic lists of RAG sessions\n  const sessions = workspace.ragSessions || [];\n  const filteredSessions = sessions.filter(s => \n    s.title.toLowerCase().includes(sessionSearch.toLowerCase())\n  );\n\n  const activeSession = sessions.find(s => s.id === activeSessionId) || sessions[0];\n\n  // Auto-scroll chat history\n  useEffect(() => {\n    chatBottomRef.current?.scrollIntoView({ behavior: \'smooth\' });\n  }, [activeSession?.messages?.length, isGeneratingAI]);\n\n  // Handle setting active session (and auto-triggers focus mode!)\n  const handleSelectSession = (id: string) => {\n    setActiveSessionId(id);\n    onToggleFocusMode(true); // Automatically enter Focus Mode for conversational immersion\n  };\n\n  // Chat Actions\n  const handleSendMessage = async (e?: React.FormEvent) => {\n    if (e) e.preventDefault();\n    if (!chatInput.trim() || !activeSession || isGeneratingAI) return;\n\n    const messageText = chatInput;\n    setChatInput(\'\');\n\n    await onSendChatMessage(activeSession.id, messageText);\n  };\n\n  const handleSuggestedPrompt = async (prompt: string) => {\n    if (!activeSession || isGeneratingAI) return;\n    await onSendChatMessage(activeSession.id, prompt);\n  };\n\n  // Session Mutations\n  const handleCreateNewSession = (e: React.FormEvent) => {\n    e.preventDefault();\n    \n    const newSession: RAGSession = {\n      id: `sess-${Date.now()}`,\n      title: `${analysisType} - ${new Date().toLocaleDateString(\'en-US\', { month: \'short\', day: \'numeric\' })}`,\n      type: analysisType,\n      scopeType: analysisScope,\n      selectedIds: selectedScopeIds,\n      customInstructions: customBriefInstructions,\n      createdAt: new Date().toISOString(),\n      messages: [\n        {\n          id: `m-${Date.now()}-init`,\n          role: \'assistant\',\n          text: `### \360\237\244\226 RAG Analysis Session Established\nI have synced focus criteria onto: **${analysisType}** (${analysisScope.toUpperCase()} Scope).\n          \n* **Class contexts & Instructions loaded**: Checked (${workspace.instructions.length} custom guidelines parsed)\n* **Parent logs & grades directory**: Synced (${workspace.students.length} portfolios indexed)\n          \nHow can I assist you with clinical evaluation reviews today? You can select a quick action suggestion below or draft custom requests directly.`,\n          timestamp: new Date().toISOString()\n        }\n      ]\n    };\n\n    onUpdateWorkspace(workspace.id, {\n      ragSessions: [newSession, ...sessions]\n    });\n\n    setActiveSessionId(newSession.id);\n    setShowNewSessionModal(false);\n    onToggleFocusMode(true); // enter focus mode right away\n\n    // Clear form states\n    setCustomBriefInstructions(\'\');\n    setSelectedScopeIds([]);\n  };\n\n  const handleDuplicateSession = (id: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    const target = sessions.find(s => s.id === id);\n    if (!target) return;\n\n    const duplicated: RAGSession = {\n      ...target,\n      id: `sess-${Date.now()}`,\n      title: `${target.title} (Copy)`,\n      createdAt: new Date().toISOString(),\n      messages: [...target.messages]\n    };\n\n    onUpdateWorkspace(workspace.id, {\n      ragSessions: [duplicated, ...sessions]\n    });\n  };\n\n  const handleDeleteSession = (id: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    const filtered = sessions.filter(s => s.id !== id);\n    onUpdateWorkspace(workspace.id, { ragSessions: filtered });\n    if (activeSessionId === id) {\n      setActiveSessionId(filtered[0]?.id || null);\n    }\n  };\n\n  // Preset prompts list\n  const suggestedChips = [\n    { label: \"Sofia Learning Gaps\", prompt: \"Summarize Sofia Patel\'s performance regression. What are the key Socratic feedback comments I should write on her written submissions?\" },\n    { label: \"Class Evaluation Matrix\", prompt: \"Create a topical grade mastery matrix comparing Aarav and Sofia across Polynomials and Geometry assessments.\" },\n    { label: \"Parent briefing agenda\", prompt: \"Generate a bullet-pointed parent BRIEF for Sofia Patel\'s father, Vikram. Suggest direct support tips for home revision.\" },\n    { label: \"Exam Syllabus audit\", prompt: \"Audit our curriculum materials syllabus for algebra and recommend 3 structural remedial quiz prompts.\" }\n  ];\n\n  return (\n    <div className=\"flex-1 flex overflow-hidden border border-slate-850/60 rounded-3xl bg-[#070b16]/75 relative h-full\">\n      \n      {/* 2. RAG Left Sessions list panel */}\n      <div className=\"w-64 border-r border-slate-850/50 flex flex-col bg-slate-950/20 shrink-0\">\n        \n        {/* Panel header controls */}\n        <div className=\"p-4 border-b border-slate-850/50 space-y-3 shrink-0\">\n          <button \n            onClick={() => setShowNewSessionModal(true)}\n            className=\"w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-xs py-2.5 px-4 rounded-xl flex items-center justify-center gap-2 shadow-lg hover:shadow-indigo-500/10 transition-all cursor-pointer\"\n          >\n            <Plus className=\"w-4 h-4\" />\n            New AI Analysis\n          </button>\n          \n          <input \n            type=\"text\" \n            placeholder=\"Search diagnostics...\"\n            value={sessionSearch}\n            onChange={(e) => setSessionSearch(e.target.value)}\n            className=\"w-full bg-slate-900 border border-slate-800 rounded-lg px-2.5 py-1.5 text-xs text-slate-300 placeholder-slate-500 focus:outline-none\"\n          />\n        </div>\n\n        {/* Existing Analyses sessions */}\n        <div className=\"flex-1 overflow-y-auto p-2 space-y-1\">\n          <span className=\"text-[10px] font-bold font-mono text-slate-500 block uppercase px-3 py-1 bg-transparent\">Conversations History</span>\n          \n          {filteredSessions.length === 0 ? (\n            <div className=\"text-[11px] font-mono p-4 text-slate-600 text-center border border-dashed border-slate-800/40 rounded-xl m-2 bg-slate-900/10\">\n              No analyses logged. Initiate high-speed RAG analysis above.\n            </div>\n          ) : (\n            filteredSessions.map(sec => {\n              const isActive = sec.id === (activeSession?.id);\n              return (\n                <div \n                  key={sec.id}\n                  onClick={() => handleSelectSession(sec.id)}\n                  className={`group relative flex items-center justify-between px-3 py-2.5 rounded-lg border text-xs transition-all cursor-pointer ${\n                    isActive \n                      ? \'bg-[#121c37] border-indigo-500/20 text-indigo-200\' \n                      : \'border-transparent hover:bg-slate-900/35 text-slate-350 hover:text-gray-100\'\n                  }`}\n                >\n                  <div className=\"flex items-center gap-2 truncate\">\n                    <History className={`w-3.5 h-3.5 shrink-0 ${isActive ? \'text-indigo-400\' : \'text-slate-500\'}`} />\n                    <span className=\"truncate pr-4 font-medium\">{sec.title}</span>\n                  </div>\n\n                  <div className=\"opacity-0 group-hover:opacity-100 flex items-center gap-1 shrink-0 bg-transparent\" onClick={e => e.stopPropagation()}>\n                    <button \n                      onClick={(e) => handleDuplicateSession(sec.id, e)}\n                      className=\"p-0.8 hover:bg-slate-800 text-slate-500 hover:text-indigo-400 rounded transition-all cursor-pointer\"\n                      title=\"Duplicate Chat Session\"\n                    >\n                      <Copy className=\"w-3 h-3\" />\n                    </button>\n                    <button \n                      onClick={(e) => handleDeleteSession(sec.id, e)}\n                      className=\"p-0.8 hover:bg-red-500/10 text-slate-500 hover:text-red-400 rounded transition-all cursor-pointer\"\n                      title=\"Delete Chat (Does NOT impact roster records)\"\n                    >\n                      <Trash2 className=\"w-3 h-3\" />\n                    </button>\n                  </div>\n                </div>\n              );\n            })\n          )}\n        </div>\n\n      </div>\n\n      {/* 3. Main chat chatbot workspace pane */}\n      <div className=\"flex-1 flex flex-col justify-between bg-slate-950/10 relative overflow-hidden h-full\">\n        \n        {/* Header bar */}\n        <div className=\"p-4 border-b border-slate-850/50 bg-slate-900/30 shrink-0 flex items-center justify-between z-30\">\n          <div className=\"flex items-center gap-2.5\">\n            <Bot className=\"w-5 h-5 text-indigo-400\" />\n            <div>\n              <h2 className=\"text-xs font-bold text-gray-200 uppercase font-display tracking-wider\">\n                {activeSession?.title || \'Classroom Assistant Chat\'}\n              </h2>\n              <span className=\"text-[10px] font-mono text-slate-500\">Live Server Agent: Gemini 3.5 Flash</span>\n            </div>\n          </div>\n\n          {/* Focus Mode toggles */}\n          <div className=\"flex items-center gap-2\">\n            {isFocusMode ? (\n              <button \n                onClick={() => onToggleFocusMode(false)}\n                className=\"px-3.5 py-1.8 bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-300 hover:text-indigo-200 border border-indigo-500/30 text-xs font-semibold rounded-xl flex items-center gap-1.5 cursor-pointer\"\n              >\n                <ArrowLeft className=\"w-4 h-4\" />\n                Back to Split Workspace\n              </button>\n            ) : (\n              <button \n                onClick={() => onToggleFocusMode(true)}\n                className=\"p-2 hover:bg-slate-850 text-slate-400 hover:text-gray-100 rounded-xl transition-colors cursor-pointer\"\n                title=\"Enter Distraction-Free Focus Mode\"\n              >\n                <Maximize2 className=\"w-4 h-4\" />\n              </button>\n            )}\n          </div>\n        </div>\n\n        {/* Chat message streams list */}\n        <div className=\"flex-1 overflow-y-auto p-6 space-y-5\">\n          {(!activeSession || !activeSession.messages || activeSession.messages.length === 0) ? (\n            <div className=\"max-w-xl mx-auto text-center py-20 space-y-4\">\n              <Bot className=\"w-12 h-12 text-indigo-500 mx-auto animate-bounce\" />\n              <h3 className=\"text-lg font-bold font-display text-gray-200\">Initiate AI Diagnostic Sessions</h3>\n              <p className=\"text-xs text-slate-400 leading-relaxed\">\n                Choose an existing chat logs scope on the sidebar, click \"New AI Analysis\" to launch a specific lesson evaluation, or try suggesting prompt buttons.\n              </p>\n            </div>\n          ) : (\n            activeSession.messages.map(msg => {\n              const isAssistant = msg.role === \'assistant\';\n              return (\n                <div \n                  key={msg.id}\n                  className={`flex gap-4 ${isAssistant ? \'\' : \'justify-end animate-fade-in\'}`}\n                >\n                  {isAssistant && (\n                    <div className=\"w-8 h-8 rounded-full bg-[#131d35] border border-indigo-500/30 flex items-center justify-center text-indigo-400 shrink-0\">\n                      <Bot className=\"w-4 h-4\" />\n                    </div>\n                  )}\n\n                  <div className={`space-y-3.5 max-w-[85%] ${isAssistant ? \'\' : \'flex flex-col items-end\'}`}>\n                    \n                    {/* Chat Text Bubble */}\n                    <div className={`p-4 rounded-2xl border text-xs leading-relaxed leading-normal transition-colors ${\n                      isAssistant \n                        ? \'bg-[#0f172a]/60 border-slate-850/65 text-slate-200 shadow-sm\' \n                        : \'bg-indigo-600 border-indigo-500 text-white font-medium\'\n                    }`}>\n                      <div className=\"space-y-3 prose prose-invert text-xs select-text\">\n                        {/* Process markdown text blocks simply */}\n                        {msg.text.split(\'\\n\\n\').map((para, pIdx) => {\n                          if (para.startsWith(\'###\')) {\n                            return <h3 key={pIdx} className=\"text-sm font-bold font-display text-indigo-300 mt-2 pb-1.5 border-b border-slate-800/40\">{para.replace(\'###\', \'\').trim()}</h3>;\n                          }\n                          if (para.startsWith(\'####\')) {\n                            return <h4 key={pIdx} className=\"text-xs font-bold text-slate-200 mt-1\">{para.replace(\'####\', \'\').trim()}</h4>;\n                          }\n                          if (para.startsWith(\'**\') || para.trim().startsWith(\'-\')) {\n                            const listItems = para.split(\'\\n\').filter(l => l.trim().length > 0);\n                            return (\n                              <ul key={pIdx} className=\"list-disc pl-4 space-y-1\">\n                                {listItems.map((li, liIdx) => (\n                                  <li key={liIdx}>\n                                    {li.replace(/^(\\s*-\\s*|\\s*\\*\\s*)/, \'\').replace(/\\*\\*(.*?)\\*\\*/g, \'$1\')}\n                                  </li>\n                                ))}\n                              </ul>\n                            );\n                          }\n                          return <p key={pIdx}>{para}</p>;\n                        })}\n                      </div>\n                    </div>\n\n                    {/* Dynamic Pure SVG Visualizer widget inside assistant bubbles */}\n                    {isAssistant && msg.visualization && (\n                      <div className=\"bg-[#0c1222]/85 border border-slate-800/80 rounded-2xl p-4 w-full md:min-w-[480px] hover:border-slate-800 transition-colors shadow-xl\">\n                        <div className=\"pb-3 border-b border-slate-800/60 mb-4\">\n                          <span className=\"text-[9px] font-mono font-bold uppercase tracking-wider text-indigo-400\">Class Visualizer</span>\n                          <h4 className=\"text-xs font-bold text-gray-200 mt-1\">{msg.visualization.title}</h4>\n                          {msg.visualization.description && (\n                            <p className=\"text-[10px] text-slate-500 font-mono mt-0.5\">{msg.visualization.description}</p>\n                          )}\n                        </div>\n\n                        {/* RENDER SELECTED SVG VISUALIZER */}\n                        {renderSvgVisualizer(msg.visualization)}\n                      </div>\n                    )}\n\n                    <span className=\"text-[9px] font-mono text-slate-500 font-medium px-1\">\n                      {new Date(msg.timestamp).toLocaleTimeString(\'en-US\', { hour: \'2-digit\', minute: \'2-digit\' })}\n                    </span>\n                  </div>\n\n                  {!isAssistant && (\n                    <div className=\"w-8 h-8 rounded-full bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 shrink-0\">\n                      <User className=\"w-4 h-4\" />\n                    </div>\n                  )}\n                </div>\n              );\n            })\n          )}\n\n          {/* Thinking Loading animation skeleton */}\n          {isGeneratingAI && (\n            <div className=\"flex gap-4 p-1 animate-pulse\">\n              <div className=\"w-8 h-8 rounded-full bg-[#131d35] border border-indigo-500/10 flex items-center justify-center text-indigo-400 shrink-0\">\n                <Brain className=\"w-4.5 h-4.5 text-indigo-400 animate-spin\" />\n              </div>\n              <div className=\"space-y-2.5 max-w-[70%]\">\n                <div className=\"bg-slate-900 border border-slate-850 rounded-2xl p-4 flex flex-col gap-2 w-72\">\n                  <span className=\"text-[10px] font-mono text-indigo-400\">AI Thinking & Grading Submissions...</span>\n                  <div className=\"h-2 bg-slate-800 rounded w-full\"></div>\n                  <div className=\"h-2 bg-slate-800 rounded w-5/6\"></div>\n                  <div className=\"h-2 bg-slate-800 rounded w-2/3\"></div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          <div ref={chatBottomRef} />\n        </div>\n\n        {/* Suggestion Prompt Chips Bottom bar */}\n        {sessions.length > 0 && activeSession?.messages?.length <= 2 && !isGeneratingAI && (\n          <div className=\"px-6 py-2 shrink-0 flex items-center gap-2 overflow-x-auto scrollbar-none z-20\">\n            <span className=\"text-[9px] font-mono text-slate-500 font-bold shrink-0\">Quick Gaps:</span>\n            {suggestedChips.map((chip, idx) => (\n              <button \n                key={idx}\n                onClick={() => handleSuggestedPrompt(chip.prompt)}\n                className=\"px-3 py-1 bg-indigo-500/5 hover:bg-indigo-500/15 border border-indigo-500/10 text-indigo-300 rounded-lg text-[10px] font-medium transition-colors cursor-pointer shrink-0\"\n              >\n                {chip.label}\n              </button>\n            ))}\n          </div>\n        )}\n\n        {/* Primary chat control form bar */}\n        <div className=\"p-4 border-t border-slate-850/50 bg-[#070b16]\">\n          <form onSubmit={handleSendMessage} className=\"relative flex items-center bg-slate-900 border border-slate-800 rounded-2xl p-2 focus-within:border-indigo-500/50 focus-within:ring-1 focus-within:ring-indigo-500/20 transition-all\">\n            \n            <input \n              type=\"text\" \n              placeholder=\"Ask AI Copilot to grade assessments, calculate topic mastery regression, or write parent tips...\"\n              value={chatInput}\n              onChange={(e) => setChatInput(e.target.value)}\n              disabled={isGeneratingAI || !activeSession}\n              className=\"flex-1 bg-transparent text-xs text-slate-200 pl-3 pr-16 py-2 outline-none placeholder-slate-500\"\n            />\n\n            <button \n              type=\"submit\"\n              disabled={!chatInput.trim() || isGeneratingAI || !activeSession}\n              className=\"absolute right-3 top-3 p-1.5 rounded-xl bg-indigo-600 hover:bg-indigo-500 disabled:bg-slate-800 disabled:text-slate-600 text-white transition-all cursor-pointer\"\n            >\n              <Send className=\"w-3.5 h-3.5\" />\n            </button>\n          </form>\n          <p className=\"text-[10px] text-slate-600 font-mono text-center mt-2.5\">\n            Press Enter to submit. EduCopilot evaluates syllabus documents and custom student rosters in real-time.\n          </p>\n        </div>\n\n      </div>\n\n      {/* NEW SESSION MODAL ON DEMAND */}\n      {showNewSessionModal && (\n        <div className=\"fixed inset-0 bg-slate-950/80 backdrop-blur-md flex items-center justify-center p-4 z-50 animate-fade-in\">\n          <div className=\"bg-[#0b0f19] border border-slate-800 rounded-3xl max-w-xl w-full p-6 space-y-4 shadow-3xl relative\">\n            <button \n              onClick={() => setShowNewSessionModal(false)}\n              className=\"absolute right-4 top-4 hover:bg-slate-850 p-1.5 rounded-lg text-slate-500 hover:text-gray-200 transition-colors cursor-pointer\"\n            >\n              <X className=\"w-4 h-4\" />\n            </button>\n\n            <div className=\"flex items-center gap-2 pb-2.5 border-b border-slate-850\">\n              <Sparkles className=\"w-5 h-5 text-indigo-400 animate-pulse\" />\n              <div>\n                <h3 className=\"text-sm font-semibold text-gray-150\">Start Diagnostic Analysis</h3>\n                <span className=\"text-[10px] font-mono text-slate-500\">Retrieval Augmented Generation Workspace</span>\n              </div>\n            </div>\n\n            <form onSubmit={handleCreateNewSession} className=\"space-y-4\">\n              \n              {/* Type Grid */}\n              <div>\n                <label className=\"text-[10px] font-mono text-slate-500 uppercase tracking-wider block mb-1.5\">Analysis Target Type</label>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  {[\n                    \'Student Performance Analysis\',\n                    \'Class Strength Analysis\',\n                    \'Weak Topic Detection\',\n                    \'Question Paper Analysis\',\n                    \'Learning Gap Analysis\',\n                    \'Parent Report Generation\',\n                    \'Custom\'\n                  ].map(type => (\n                    <div \n                      key={type}\n                      onClick={() => setAnalysisType(type)}\n                      className={`px-3 py-2 border rounded-xl text-xs font-semibold cursor-pointer transition-colors ${\n                        analysisType === type \n                          ? \'border-indigo-500/80 bg-indigo-500/5 text-indigo-300 shadow-md\' \n                          : \'border-slate-850/50 hover:bg-slate-900/30 text-slate-400\'\n                      }`}\n                    >\n                      {type}\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n              {/* Scope selectors */}\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 uppercase block mb-1.5\">Focus Scope Bounds</label>\n                  <select \n                    value={analysisScope}\n                    onChange={(e) => setAnalysisScope(e.target.value as any)}\n                    className=\"w-full bg-slate-900 border border-slate-800 rounded-lg p-2 text-xs text-gray-350 cursor-pointer outline-none\"\n                  >\n                    <option value=\"class\">Entire Class Cohort</option>\n                    <option value=\"students\">Selected Students only</option>\n                    <option value=\"materials\">Uploaded Materials Repository</option>\n                    <option value=\"assessments\">Scored Grades Database</option>\n                  </select>\n                </div>\n\n                <div>\n                  <label className=\"text-[10px] font-mono text-slate-500 uppercase block mb-1.5\">Select specific bounds</label>\n                  {analysisScope === \'class\' ? (\n                    <div className=\"text-[11px] font-mono py-2 text-indigo-400 leading-normal\">\n                      Full class of {workspace.students.length} students indexed.\n                    </div>\n                  ) : (\n                    <div className=\"max-h-20 overflow-y-auto border border-slate-850 rounded-lg p-1.5 bg-slate-900 space-y-1\">\n                      {analysisScope === \'students\' && workspace.students.map(s => (\n                        <label key={s.id} className=\"flex items-center gap-1.5 text-xs text-slate-300\">\n                          <input \n                            type=\"checkbox\" \n                            checked={selectedScopeIds.includes(s.id)}\n                            onChange={(e) => {\n                              if (e.target.checked) setSelectedScopeIds([...selectedScopeIds, s.id]);\n                              else setSelectedScopeIds(selectedScopeIds.filter(id => id !== s.id));\n                            }}\n                          />\n                          {s.name}\n                        </label>\n                      ))}\n                      {analysisScope === \'materials\' && workspace.materials.map(m => (\n                        <label key={m.id} className=\"flex items-center gap-1.5 text-xs text-slate-350\">\n                          <input \n                            type=\"checkbox\" \n                            checked={selectedScopeIds.includes(m.id)}\n                            onChange={(e) => {\n                              if (e.target.checked) setSelectedScopeIds([...selectedScopeIds, m.id]);\n                              else setSelectedScopeIds(selectedScopeIds.filter(id => id !== m.id));\n                            }}\n                          />\n                          {m.name}\n                        </label>\n                      ))}\n                      {analysisScope === \'assessments\' && (\n                        <div className=\"text-[11px] font-mono text-indigo-400\">All quiz scoring records synced.</div>\n                      )}\n                    </div>\n                  )}\n                </div>\n              </div>\n\n              {/* Custom micro guidelines */}\n              <div>\n                <label className=\"text-[10px] font-mono text-slate-500 block mb-1\">OPTIONAL BRIEFING INSTRUCTIONS</label>\n                <textarea \n                  placeholder=\"Provide precise analysis directions, e.g. Cross-compare Aarav and Sofia\'s polynomials homework sheets specifically and look for IEP accommodations requirements...\"\n                  value={customBriefInstructions}\n                  onChange={(e) => setCustomBriefInstructions(e.target.value)}\n                  className=\"w-full bg-slate-900 border border-slate-800 rounded-lg p-2.5 text-xs text-slate-300 h-20 resize-none outline-none focus:border-indigo-500\"\n                />\n              </div>\n\n              <button \n                type=\"submit\"\n                className=\"w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-2 rounded-xl text-xs transition-colors shadow-lg cursor-pointer\"\n              >\n                Establish Chat Analysis Context\n              </button>\n\n            </form>\n          </div>\n        </div>\n      )}\n\n    </div>\n  );\n}\n\n// Interactive Pure SVG visualizer compiler\nfunction renderSvgVisualizer(visualization: any) {\n  const { type, data } = visualization;\n  if (!Array.isArray(data) || data.length === 0) return null;\n\n  switch (type) {\n    case \'ranking\':\n      return (\n        <div className=\"space-y-3 font-mono text-[11px]\">\n          {data.map((item: any, idx: number) => {\n            const pct = (item.score / 100) * 100;\n            return (\n              <div key={idx} className=\"space-y-1\">\n                <div className=\"flex justify-between text-slate-300\">\n                  <span className=\"font-semibold text-slate-200\">{item.name}</span>\n                  <span className=\"text-indigo-400 font-bold\">{item.score}%</span>\n                </div>\n                <div className=\"w-full h-2.5 bg-slate-900/80 border border-slate-850 rounded-full overflow-hidden flex relative\">\n                  <div \n                    className=\"h-full bg-gradient-to-r from-indigo-500 to-indigo-400 rounded-full transition-all duration-1000\"\n                    style={{ width: `${pct}%` }}\n                  ></div>\n                  {/* Class average guide overlay */}\n                  <div \n                    className=\"absolute h-full w-[2px] bg-emerald-400 top-0\"\n                    style={{ left: `${item.classAvg || 80}%` }}\n                    title=\"Class Average Line\"\n                  ></div>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      );\n\n    case \'timeline\':\n      // Renders score trajectory pathways simply using raw clean SVGs polylines\n      const points = data.map((item: any, idx: number) => {\n        const x = 50 + idx * 140;\n        const y = 140 - (item.SofiaScore || item.score || 50) * 1.1; // scale y\n        return { x, y, label: item.period || item.date };\n      });\n      const polylinePoints = points.map((p: any) => `${p.x},${p.y}`).join(\' \');\n\n      return (\n        <div className=\"flex flex-col gap-2\">\n          <svg className=\"w-full h-36 bg-slate-950/40 rounded-xl border border-slate-850 p-2\" viewBox=\"0 0 400 150\">\n            {/* Grid references lines */}\n            <line x1=\"40\" y1=\"30\" x2=\"380\" y2=\"30\" stroke=\"#1e293b\" strokeDasharray=\"3\" />\n            <line x1=\"40\" y1=\"85\" x2=\"380\" y2=\"85\" stroke=\"#1e293b\" strokeDasharray=\"3\" />\n            <line x1=\"40\" y1=\"130\" x2=\"380\" y2=\"130\" stroke=\"#1e293b\" strokeDasharray=\"3\" />\n\n            {/* Connecting Pathway vector line */}\n            <polyline \n              fill=\"none\" \n              stroke=\"#6366f1\" \n              strokeWidth=\"2.5\" \n              points={polylinePoints} \n              className=\"transition-all\"\n            />\n\n            {/* Marker Nodes */}\n            {points.map((p: any, idx: number) => (\n              <g key={idx}>\n                <circle \n                  cx={p.x} \n                  cy={p.y} \n                  r=\"5\" \n                  className=\"fill-[#0b0f19] stroke-indigo-400 stroke-2\" \n                />\n                <text \n                  x={p.x} \n                  y={p.y - 12} \n                  textAnchor=\"middle\" \n                  fill=\"#818cf8\" \n                  fontSize=\"10\" \n                  fontFamily=\"monospace\"\n                >\n                  {Math.round(140 - p.y) / 1.1}%\n                </text>\n                <text \n                  x={p.x} \n                  y=\"145\" \n                  textAnchor=\"middle\" \n                  fill=\"#475569\" \n                  fontSize=\"8\" \n                  fontFamily=\"monospace\"\n                >\n                  {p.label}\n                </text>\n              </g>\n            ))}\n          </svg>\n        </div>\n      );\n\n    case \'heatmap\':\n      return (\n        <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3\">\n          {data.map((item: any, idx: number) => {\n            const mastery = item.mastery || 60;\n            let theme = \'border-rose-500/20 bg-rose-500/5 text-rose-400\';\n            let label = \'Urgent Remedial\';\n            if (mastery >= 85) {\n              theme = \'border-emerald-500/20 bg-emerald-500/5 text-emerald-400\';\n              label = \'Secure Mastery\';\n            } else if (mastery >= 70) {\n              theme = \'border-indigo-500/20 bg-indigo-500/5 text-indigo-400\';\n              label = \'Developing\';\n            }\n\n            return (\n              <div key={idx} className={`border rounded-xl p-3 flex flex-col gap-1 transition-colors ${theme}`}>\n                <span className=\"text-[9px] font-mono font-bold tracking-wider block uppercase\">{label}</span>\n                <span className=\"text-xs font-bold font-display truncate block mt-1\">{item.topic || item.subject}</span>\n                <h5 className=\"text-md font-extrabold font-mono mt-1\">{mastery}%</h5>\n              </div>\n            );\n          })}\n        </div>\n      );\n\n    case \'stats\':\n    default:\n      return (\n        <div className=\"grid grid-cols-2 gap-3.5\">\n          {data.map((item: any, idx: number) => (\n            <div key={idx} className=\"bg-slate-900/60 border border-slate-850/60 rounded-xl p-3 flex flex-col justify-between\">\n              <span className=\"text-[10px] font-mono text-slate-500 block uppercase leading-tight\">{item.label}</span>\n              <span className=\"text-xs font-bold text-slate-200 mt-2 block break-words\">{item.value}</span>\n            </div>\n          ))}\n        </div>\n      );\n  }\n}\n"
    }
    diff {
      unified_diff {
        lines {
          text: "import React, { useState, useRef, useEffect } from \'react\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
